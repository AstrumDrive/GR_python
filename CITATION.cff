    given-names: "Nelson"
    affiliation: "Astrum Drive"
repository-code: "https://github.com/AstrumDrive/GR_python"
url: "https://github.com/AstrumDrive/GR_python"
doi: "10.5281/zenodo.18974740"
keywords:
  - general relativity
  - symbolic computation
  - sympy
  - tensor calculus
  - spacetime metrics
  - warp metrics
